[System]
WebServer=1
DefaultServer=iris-primary

[AppServer:iris-primary]
Server=iris-primary
Port=1972
Username=CSPSystem
Password=SYS
Application=/csp/
Events=1
Timeout=900

[AppServer:iris-async]
Server=iris-async
Port=1972
Username=CSPSystem
Password=SYS
Application=/csp/
Events=1
Timeout=900

[ApplicationPath:/csp/]
Servers=iris-primary,iris-async
DefaultServer=iris-primary
CSPConfigName=iris-primary